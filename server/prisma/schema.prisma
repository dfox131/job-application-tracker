generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id          String   @id @default(uuid())
  company     String
  role        String
  status      String   @default("APPLIED")
  source      String?
  salary      String?
  location    String?
  dateApplied DateTime?
  link        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([company])
}